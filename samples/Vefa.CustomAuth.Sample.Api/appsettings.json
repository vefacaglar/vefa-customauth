{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CustomAuth": {
    "Authority": "http://localhost:5175",
    "RequireHttpsMetadata": false,
    "ValidAudiences": [
      "sample-webapp",
      "swagger-ui"
    ]
  },
  "Swagger": {
    "Title": "Vefa.CustomAuth Sample Protected API",
    "Description": "A sample protected API demonstrating OAuth2 JWT Bearer token authentication issued by Vefa.CustomAuth Server.",
    "ClientId": "swagger-ui",
    "ClientSecret": "not-required-for-pkce",
    "AppName": "Vefa.CustomAuth Swagger Client"
  }
}
