@page
@model Vefa.CustomAuth.Sample.AuthServer.Pages.LogoutModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign out - CustomAuth</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #0d0f12;
            color: #ffffff;
            font-family: 'Outfit', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .container {
            background: rgba(20, 24, 33, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 2.5rem 2rem;
            border-radius: 24px;
            backdrop-filter: blur(16px);
            max-width: 400px;
            width: 90%;
            text-align: center;
        }
        h1 { font-size: 1.5rem; font-weight: 600; margin: 0 0 0.5rem; }
        p { color: #8e9cae; margin: 0 0 1.5rem; }
        .actions { display: flex; gap: 0.75rem; }
        button, a {
            flex: 1;
            display: inline-block;
            padding: 0.85rem;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            border: none;
            text-decoration: none;
            font-family: inherit;
        }
        .btn-confirm {
            background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
            color: #ffffff;
        }
        .btn-cancel {
            background: rgba(255, 255, 255, 0.05);
            color: #ffffff;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Sign out?</h1>
        <p>You are about to end your session.</p>
        <form method="post" action="/connect/logout">
            @Html.AntiForgeryToken()
            <input type="hidden" name="post_logout_redirect_uri" value="@Model.PostLogoutRedirectUri" />
            <input type="hidden" name="state" value="@Model.State" />
            <input type="hidden" name="client_id" value="@Model.ClientId" />
            <div class="actions">
                <a href="/" class="btn-cancel">Cancel</a>
                <button type="submit" class="btn-confirm">Sign out</button>
            </div>
        </form>
    </div>
</body>
</html>
