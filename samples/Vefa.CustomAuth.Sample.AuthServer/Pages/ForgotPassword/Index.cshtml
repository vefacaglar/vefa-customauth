@page
@model Vefa.CustomAuth.Sample.AuthServer.Pages.ForgotPassword.IndexModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="container">
    <div class="header">
        <h1>Reset Password</h1>
        <div class="subtitle">recover access to your account</div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert-error">
            <span>@Model.ErrorMessage</span>
        </div>
    }

    @if (!Model.IsIdentityEnabled)
    {
        <div class="alert-error" style="text-align: center; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem;">
            <strong style="font-weight: 400; color: var(--text-primary);">Password Reset Unavailable</strong>
            <span style="font-size: 0.825rem; color: var(--text-secondary);">
                ASP.NET Core Identity is disabled in this environment. Set <code>UseAspNetCoreIdentity</code> to <code>true</code> in configuration to enable user persistence.
            </span>
        </div>

        <div class="auth-footer">
            <a href="/Login?ReturnUrl=@System.Net.WebUtility.UrlEncode(Model.ReturnUrl ?? "")" class="auth-link">Go back to Sign In</a>
        </div>
    }
    else if (Model.Submitted)
    {
        <div class="alert-success">
            <span>Reset instructions sent! Check your inbox (or simulated debug links below).</span>
        </div>

        @if (!string.IsNullOrEmpty(Model.ResetLink))
        {
            <div class="demo-box" style="margin-top: 1rem; text-align: left; border-top: 1px solid var(--border-color); padding-top: 1rem;">
                <div class="demo-title" style="color: var(--accent-color); font-weight: 400; margin-bottom: 0.5rem;">Local Reset Link (Demo Debug)</div>
                <p style="font-size: 0.78rem; line-height: 1.45; color: var(--text-secondary); margin: 0 0 0.75rem 0;">
                    Since no SMTP email provider is configured in this sample, you can click the generated reset link below to test the password reset flow:
                </p>
                <a href="@Model.ResetLink" class="btn-submit" style="display: block; text-align: center; text-decoration: none; margin: 0;">Proceed to Reset Password</a>
            </div>
        }
        else
        {
            <div class="demo-box" style="margin-top: 1rem; text-align: left; border-top: 1px solid var(--border-color); padding-top: 1rem;">
                <div class="demo-title" style="color: var(--error-text);">User Not Found</div>
                <p style="font-size: 0.8rem; margin: 0.25rem 0 0 0; color: var(--text-secondary);">
                    No reset link was generated because the email <strong>@Model.Email</strong> is not registered in ASP.NET Core Identity.
                </p>
            </div>
        }

        <div class="auth-footer" style="margin-top: 2rem;">
            <a href="/Login?ReturnUrl=@System.Net.WebUtility.UrlEncode(Model.ReturnUrl ?? "")" class="auth-link">Back to Sign In</a>
        </div>
    }
    else
    {
        <form method="post">
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

            <div class="form-group">
                <label class="form-label" for="email">Email address</label>
                <div class="input-wrapper">
                    <input class="input-control" id="email" name="Email" type="email" value="@Model.Email" placeholder="Enter your registered email" required autofocus />
                </div>
            </div>

            <button type="submit" class="btn-submit">Send Reset Link</button>
        </form>

        <div class="auth-footer">
            Remember your password? <a href="/Login?ReturnUrl=@System.Net.WebUtility.UrlEncode(Model.ReturnUrl ?? "")" class="auth-link">Sign in</a>
        </div>
    }
</div>
