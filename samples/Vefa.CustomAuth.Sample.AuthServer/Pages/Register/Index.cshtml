@page
@model Vefa.CustomAuth.Sample.AuthServer.Pages.Register.IndexModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="container">
    <div class="header">
        <h1>Create Account</h1>
        <div class="subtitle">to get started with your account</div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert-error">
            <span>@Model.ErrorMessage</span>
        </div>
    }

    @if (!Model.IsIdentityEnabled)
    {
        <div class="alert-error" style="text-align: center; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem;">
            <strong style="font-weight: 400; color: var(--text-primary);">Registration Unavailable</strong>
            <span style="font-size: 0.825rem; color: var(--text-secondary);">
                ASP.NET Core Identity is disabled in this environment. Set <code>UseAspNetCoreIdentity</code> to <code>true</code> in configuration to enable user persistence.
            </span>
        </div>

        <div class="auth-footer">
            <a href="/Login?ReturnUrl=@System.Net.WebUtility.UrlEncode(Model.ReturnUrl ?? "")" class="auth-link">Go back to Sign In</a>
        </div>
    }
    else
    {
        <form method="post">
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

            <div class="form-group">
                <label class="form-label" for="username">Username</label>
                <div class="input-wrapper">
                    <input class="input-control" id="username" name="Username" value="@Model.Username" placeholder="Choose a username" required autofocus />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="email">Email address</label>
                <div class="input-wrapper">
                    <input class="input-control" id="email" name="Email" type="email" value="@Model.Email" placeholder="Enter your email" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <div class="input-wrapper">
                    <input class="input-control" id="password" name="Password" type="password" placeholder="Min. 4 characters" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="confirmPassword">Confirm Password</label>
                <div class="input-wrapper">
                    <input class="input-control" id="confirmPassword" name="ConfirmPassword" type="password" placeholder="Confirm your password" required />
                </div>
            </div>

            <button type="submit" class="btn-submit">Register</button>
        </form>

        <div class="auth-footer">
            Already have an account? <a href="/Login?ReturnUrl=@System.Net.WebUtility.UrlEncode(Model.ReturnUrl ?? "")" class="auth-link">Sign in</a>
        </div>
    }
</div>
