@page
@model Vefa.CustomAuth.Sample.AuthServer.Pages.Login.IndexModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="container">
    <div class="header">
        <h1>Sign In</h1>
        <div class="subtitle">to continue to your application</div>
    </div>

    @if (Model.Registered == true)
    {
        <div class="alert-success">
            <span>Registration successful! You can now sign in below.</span>
        </div>
    }

    @if (Model.ResetSuccess == true)
    {
        <div class="alert-success">
            <span>Your password has been successfully reset. You can now sign in below.</span>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert-error">
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

        <div class="form-group">
            <label class="form-label" for="userName">Username</label>
            <div class="input-wrapper">
                <input class="input-control" id="userName" name="userName" autocomplete="username" placeholder="Enter your username" value="@Model.UserName" required autofocus />
            </div>
        </div>

        <div class="form-group">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                <label class="form-label" style="margin-bottom: 0;" for="password">Password</label>
                <a href="/ForgotPassword?ReturnUrl=@System.Net.WebUtility.UrlEncode(Model.ReturnUrl ?? "")" class="auth-link" style="font-size: 0.8rem;">Forgot password?</a>
            </div>
            <div class="input-wrapper">
                <input class="input-control" id="password" name="password" type="password" autocomplete="current-password" placeholder="Enter your password" required />
            </div>
        </div>

        <button type="submit" class="btn-submit">Sign In</button>
    </form>

    <div class="auth-footer">
        Don't have an account? <a href="/Register?ReturnUrl=@System.Net.WebUtility.UrlEncode(Model.ReturnUrl ?? "")" class="auth-link">Sign up</a>
    </div>

    <div class="divider"></div>

    <div class="demo-box">
        <div class="demo-title">Quick Demo Access</div>
        Use credentials <span class="demo-badge">demo</span> / <span class="demo-badge">demo</span>
    </div>
</div>
