@page
@model Vefa.CustomAuth.Sample.AuthServer.Pages.Logout.IndexModel
@{
    ViewData["Title"] = "Sign out";
    ViewData["HideGlow"] = true; // Match the original black background strictly without glow if desired, or false to have the glow
}

<div class="container" style="max-width: 400px; padding: 2.5rem 2rem; border-radius: 24px; text-align: center;">
    <h1 style="font-size: 1.5rem; font-weight: 600; margin: 0 0 0.5rem;">Sign out?</h1>
    <p style="color: #8e9cae; margin: 0 0 1.5rem;">You are about to end your session.</p>
    <form method="post" action="/connect/logout">
        @Html.AntiForgeryToken()
        <input type="hidden" name="post_logout_redirect_uri" value="@Model.PostLogoutRedirectUri" />
        <input type="hidden" name="state" value="@Model.State" />
        <input type="hidden" name="client_id" value="@Model.ClientId" />
        <div class="actions">
            <a href="/" class="btn-cancel">Cancel</a>
            <button type="submit" class="btn-confirm">Sign out</button>
        </div>
    </form>
</div>
