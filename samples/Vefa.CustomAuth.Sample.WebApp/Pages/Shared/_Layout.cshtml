<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sample Web App - @ViewData["Title"]</title>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="page-shell">
        <header class="site-header">
            <div>
                <h1>Sample Web App</h1>
                <p>Vefa.CustomAuth Integration Demo</p>
            </div>
            <div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/logout" class="button button-secondary">Sign Out</a>
                }
                else
                {
                    <a href="/login" class="button button-primary">Sign In</a>
                }
            </div>
        </header>
        
        <main>
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
