@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

@if (!Model.IsAuthenticated)
{
    <div class="intro-panel">
        <h2>Welcome to the Sample App</h2>
        <p>This application demonstrates how to integrate a relying party with Vefa.CustomAuth using OpenID Connect.</p>
        <a href="/login" class="button button-primary">Sign In with Vefa.CustomAuth</a>
    </div>
}
else
{
    <div class="dashboard-grid" x-data="appData()">
        <aside class="profile-panel">
            <div class="profile-summary">
                <div class="profile-initials">@Model.Initials</div>
                <div>
                    <h3>@Model.Name</h3>
                    <p>Authenticated User</p>
                </div>
            </div>

            <div class="action-list">
                <h4>Actions</h4>
                <button @@click="testApi" :disabled="loadingApi" class="button button-secondary full-width">
                    <span x-show="loadingApi" x-cloak>...</span>
                    Test API Request
                </button>
                <button @@click="refreshToken" :disabled="loadingRefresh" class="button button-secondary full-width">
                    <span x-show="loadingRefresh" x-cloak>...</span>
                    Refresh Token
                </button>
            </div>
        </aside>

        <section class="console-panel">
            <div class="console-header">
                <h3>Console Output</h3>
                <button @@click="clearConsole" class="link-button">Clear</button>
            </div>
            <div class="console-body" id="console-container">
                <template x-for="(log, index) in logs" :key="index">
                    <div class="log-entry">
                        <span class="log-time">[<span x-text="log.time"></span>]</span>
                        <span :class="{
                            'log-info': log.type === 'info',
                            'log-success': log.type === 'success',
                            'log-error': log.type === 'error'
                        }" x-text="log.message"></span>
                        <template x-if="log.data">
                            <pre x-text="JSON.stringify(log.data, null, 2)"></pre>
                        </template>
                    </div>
                </template>
            </div>
        </section>
    </div>
}

@section Scripts {
    <script>
        function appData() {
            return {
                logs: [],
                loadingApi: false,
                loadingRefresh: false,

                init() {
                    this.addLog('info', 'Application loaded.');
                },

                addLog(type, message, data = null) {
                    const now = new Date();
                    const timeString = now.toLocaleTimeString('en-US', { hour12: false }) + '.' + String(now.getMilliseconds()).padStart(3, '0');
                    this.logs.push({ type, message, data, time: timeString });
                    this.$nextTick(() => {
                        const container = document.getElementById('console-container');
                        if (container) {
                            container.scrollTop = container.scrollHeight;
                        }
                    });
                },

                clearConsole() {
                    this.logs = [];
                    this.addLog('info', 'Console cleared.');
                },

                async testApi() {
                    this.loadingApi = true;
                    this.addLog('info', 'Calling Sample API /weather...');

                    try {
                        const response = await fetch('/api/test-api');
                        if (!response.ok) {
                            throw new Error(`HTTP error! status: ${response.status}`);
                        }

                        const data = await response.json();
                        this.addLog('success', 'API Request Successful', data);
                    } catch (error) {
                        this.addLog('error', 'API Request Failed: ' + error.message);
                    } finally {
                        this.loadingApi = false;
                    }
                },

                async refreshToken() {
                    this.loadingRefresh = true;
                    this.addLog('info', 'Attempting to refresh token...');

                    try {
                        const response = await fetch('/api/refresh', { method: 'POST' });

                        if (!response.ok) {
                            const errorText = await response.text();
                            throw new Error(`Status ${response.status}: ${errorText}`);
                        }

                        const data = await response.json();
                        this.addLog('success', 'Token refreshed successfully!', data);
                    } catch (error) {
                        this.addLog('error', 'Token refresh failed: ' + error.message);
                    } finally {
                        this.loadingRefresh = false;
                    }
                }
            }
        }
    </script>
}
